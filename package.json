{
  "name": "print-shop-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --config vite.admin.config.js",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\"",
    "dev:platform": "concurrently \"npm run server:dev\" \"npm run dev\" \"npm run dev:admin\"",
    "migrate:products": "node server/scripts/migrateProducts.js",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "build": "vite build",
    "build:admin": "vite build --config vite.admin.config.js",
    "preview": "vite preview",
    "preview:prod": "npm run build && vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "preview:admin": "vite preview --config vite.admin.config.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.23.0",
    "mongodb-memory-server": "^10.2.0",
    "mongoose": "^9.5.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "razorpay": "^2.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.2",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.19",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.4"
  }
}
