API_PORT=4000
CLIENT_ORIGIN=http://localhost:5173
ADMIN_APP_ORIGIN=http://localhost:5174
JWT_SECRET=change-this-secret
ADMIN_NAME=Elite Empressions Admin
ADMIN_EMAIL=admin@elite-empressions.local
ADMIN_PHONE=9876543210
ADMIN_PASSWORD=EliteAdmin@123
AUTH_SUCCESS_REDIRECT=http://localhost:5174/admin/auth/callback
AUTH_FAILURE_REDIRECT=http://localhost:5174/admin/login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
VITE_API_URL=
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
VITE_STOREFRONT_URL=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000,http://127.0.0.1:3000

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Admin panel login. Leave blank locally and you get the convenience default
# from server/config.js. That default is committed to this repo, so it is a
# published credential, not a secret — in production the server refuses to seed
# the admin account without these rather than create a login anyone can read.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Razorpay. The browser receives the key id from the create-order response,
# so there is no VITE_ copy to keep in sync — set these two and the checkout
# works. RAZORPAY_WEBHOOK_SECRET is a different secret from KEY_SECRET (it is
# set on the webhook itself); without it payments succeed but orders never
# leave PaymentPending.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloudinary — where uploaded files live (product photos, studio artwork,
# order design files). Optional locally: leave blank and uploads are written to
# ./uploads, which is fine on your own machine.
#
# REQUIRED in production. Render's filesystem is ephemeral, so a disk-backed
# upload is erased on the next redeploy. Rather than lose files silently, the
# server refuses uploads with a 503 when these are unset in production; check
# `uploads.durable` on GET /api/health.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production examples for Render
# CLIENT_ORIGIN=https://your-app-name.onrender.com
# ADMIN_APP_ORIGIN=https://your-app-name.onrender.com
# AUTH_SUCCESS_REDIRECT=https://your-app-name.onrender.com/admin/auth/callback
# AUTH_FAILURE_REDIRECT=https://your-app-name.onrender.com/admin/login
# GOOGLE_CALLBACK_URL=https://your-app-name.onrender.com/api/auth/google/callback

# Optional email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=orders@elite-empressions.local
ADMIN_NOTIFICATION_EMAIL=admin@elite-empressions.local


# HMAC secret for the Razorpay webhook endpoint (set in the Razorpay dashboard when creating the webhook)
RAZORPAY_WEBHOOK_SECRET=
